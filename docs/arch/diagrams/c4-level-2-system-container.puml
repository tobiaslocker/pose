@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()
System_Boundary(poseGame, "Pose Game") {
  Container(gameRuntime, "Game Runtime", "Rust + Bevy", "Visualizes pose-controlled characters. Manages game state, audio playback, and consumes landmark streams from live or recorded sources.")
  Container(poseEngine, "Pose Inference Engine", "Implementation-agnostic", "Extracts pose landmarks from video input and streams timestamped landmark frames. Also records motion sequences for reuse.")
  Container(assetStorage, "Asset Storage", "Media and Motion Repository", "Stores recorded motion sequences and synchronized media assets. Can be local, embedded, or remote.")
}
Person(player, "Human Player", "Controls a character through body movement.")
Person(dev, "Developer", "Creates routines and tests gameplay logic.")
Rel(player, poseEngine, "Provides live video input")
Rel(poseEngine, gameRuntime, "Streams LandmarkFrames")
Rel(gameRuntime, assetStorage, "Loads motion data and media")
Rel(poseEngine, assetStorage, "Stores recorded motion sequences")
Rel(dev, assetStorage, "Authors and edits assets")
@enduml

