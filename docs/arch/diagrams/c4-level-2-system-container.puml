@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml
LAYOUT_WITH_LEGEND()

Person(user, "User", "Performs a dance or pose routine in front of a webcam")

System_Boundary(game, "Pose Game System") {
    Container(bevyApp, "Game Client", "Rust + Bevy", "Visualizes pose landmarks, records pose data, replays sequences, compares live movement to choreography, and displays feedback")
    
    Container(pythonServer, "Pose Detection Server", "Python + MediaPipe", "Captures webcam or video input, runs pose detection, streams landmarks via WebSocket (FlatBuffers)")

    ContainerDb(recordings, "Reference Pose Storage", "FlatBuffers / JSON", "Stores prerecorded pose sequences for playback and matching")
}

Rel(user, pythonServer, "Moves in front of webcam")
Rel(pythonServer, bevyApp, "WebSocket + FlatBuffers", "Sends live or video-based pose landmarks")
Rel(bevyApp, recordings, "Reads/writes pose sequences for playback and matching")
Rel(user, bevyApp, "Receives feedback via visuals/audio")
@enduml
