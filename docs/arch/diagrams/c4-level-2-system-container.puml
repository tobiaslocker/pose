@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Container.puml

System_Boundary(poseApp, "Pose App") {
  Container(game, "Game Client", "Rust + Bevy", "Renders pose skeletons, compares poses, shows score")
  Container(controller, "Python Pose Server", "Python + MediaPipe", "Streams landmark data over WebSocket")
  Container(fileInput, "Playback Source", "FlatBuffers/JSON", "Feeds prerecorded pose data")
}

Person(user, "User", "Performs movements")

Rel(user, controller, "Provides live webcam input")
Rel(controller, game, "Streams pose landmarks")
Rel(fileInput, game, "Feeds prerecorded frames")
Rel(game, user, "Shows visualization and score")
@enduml

