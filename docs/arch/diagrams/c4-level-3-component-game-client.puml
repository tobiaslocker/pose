@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
LAYOUT_WITH_LEGEND()

Container_Boundary(game, "Game Client (Rust + Bevy)") {
    Component(payloadStream, "FramedPayloadStream", "WebSocket-based framed FlatBuffer stream (ws module)")
    Component(detectionProvider, "DetectionProvider", "Receives pose frames from PayloadStream via channel")
    Component(detectionResource, "Detection Resource", "ECS resource holding latest pose frame")
    Component(skeleton, "Skeleton Renderer", "Updates pose landmark sprites and draws bones")
    Component(recording, "RecordingBuffer", "Records streamed pose frames with timestamps")
    Component(playback, "PlaybackController", "Feeds recorded frames into ECS for playback")
    Component(matching, "PoseMatcher", "Compares live pose vs. playback (planned)")
}

Rel(payloadStream, detectionProvider, "Pushes parsed DetectionResult")
Rel(detectionProvider, detectionResource, "Polled each frame")
Rel(detectionResource, skeleton, "Provides pose data for rendering")
Rel(detectionProvider, recording, "Records DetectionResult when enabled")
Rel(playback, detectionResource, "Feeds playback frame into ECS")
Rel(detectionResource, matching, "Provides live pose")
Rel(playback, matching, "Provides reference pose")
@enduml
