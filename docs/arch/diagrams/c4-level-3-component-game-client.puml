@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

Container(game, "Game Client", "Rust + Bevy")

Component(landmarkStream, "Landmark Stream", "Trait", "Unified interface for pose sources")
Component(wsStream, "ws_stream", "System", "Receives live frames over WebSocket")
Component(fileStream, "file_stream", "System", "Feeds frames from file")
Component(scorePose, "score_pose_similarity", "System", "Compares live and reference poses")
Component(draw, "draw_character", "System", "Renders landmark skeletons")
Component(ui, "update_score_text", "System", "Displays score as text")
Component(setup, "setup", "System", "Spawns camera, audio, entities")

Rel(setup, wsStream, "Spawns")
Rel(setup, fileStream, "Spawns")
Rel(wsStream, landmarkStream, "Implements")
Rel(fileStream, landmarkStream, "Implements")
Rel(scorePose, landmarkStream, "Reads")
Rel(draw, landmarkStream, "Visualizes")
Rel(ui, scorePose, "Reads score")

@enduml
